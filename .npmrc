# pnpm config (repo is on pnpm 10, `packageManager` field in package.json).
# shamefully-hoist keeps a flat `node_modules/<pkg>/` layout so direct paths
# like `tsx ../../node_modules/knex/bin/cli.js` continue to resolve.
shamefully-hoist=true
# Honor npm-era behavior of legacy peer deps so transitive peer-dep
# conflicts don't block installs.
auto-install-peers=true
strict-peer-dependencies=false
