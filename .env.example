# ---------------------------------------------------------------------------
# Local development defaults. Copy to `.env` and tweak.
# ---------------------------------------------------------------------------
# Service ports — change these if you have conflicts on your host. In CI,
# these should be picked from the kernel's ephemeral range at runtime, not
# set here. See `scripts/pick-port.sh`.
# ---------------------------------------------------------------------------

# Backend (Express)
SERVER_HOST=0.0.0.0
SERVER_PORT=3001

# Dapr sidecar (HTTP)
DAPR_HOST=localhost
DAPR_PORT=3500

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_SCHEMA=backend_ts

# Frontend
# Next.js — `next dev` reads PORT (Next convention)
NEXTJS_PORT=3000

# Observability
ZIPKIN_PORT=9411
OTLP_PORT=4318
DAPR_DASHBOARD_PORT=8888

# Dapr control plane
PLACEMENT_PORT=50005
SCHEDULER_PORT=50006

# Redis (Dapr state + pubsub backend)
REDIS_PORT=6379

# Grafana (when otel stack is enabled)
GRAFANA_OTEL_PORT=3200

# JWT signing key for local auth. Rotate in non-dev environments.
JWT_SECRET_KEY=secret

# Dapr secretstore (backend reads DB credentials through this)
SECRETS_KEY=serviceSecrets
SECRETS_STORE_NAME=local-secretstore

# Dapr app-id of the backend service (web-nextjs targets this via invoke)
BACKEND_APP_ID=backend-ts

# Runtime
NODE_ENV=development
LOG_LEVEL=debug
