# syntax=docker/dockerfile:1@sha256:2780b5c3bab67f1f76c781860de469442999ed1a0d7992a5efdf2cffc0e3d769
# Build
FROM docker.io/node:24-alpine@sha256:d1b3b4da11eefd5941e7f0b9cf17783fc99d9c6fc34884a665f40a06dbdfc94f AS build
ENV NODE_ENV=development
RUN corepack enable && corepack prepare pnpm@10.33.2 --activate
WORKDIR /app
COPY package.json .npmrc next.config.ts postcss.config.mjs tsconfig.json eslint.config.mjs ./
RUN pnpm install
WORKDIR /app/public
COPY public ./

# Run
FROM docker.io/node:24-alpine@sha256:d1b3b4da11eefd5941e7f0b9cf17783fc99d9c6fc34884a665f40a06dbdfc94f AS runtime
RUN corepack enable && corepack prepare pnpm@10.33.2 --activate
WORKDIR /app
COPY --from=build /app /app
COPY /src /app/src
EXPOSE 3001
# Dev-only image: docker-compose bind-mounts ./src and `next dev` writes
# `.next/` cache into the working directory. With `USER node`, host
# UID/GID mismatch on the bind mount causes EACCES. The DS-0002 trivy
# finding is suppressed for this file in `.trivyignore.yaml` — the prod
# runtime image (`Dockerfile`) does run as `node`.
CMD [ "pnpm", "run", "dev" ]
