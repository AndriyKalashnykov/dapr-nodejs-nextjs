# syntax=docker/dockerfile:1@sha256:2780b5c3bab67f1f76c781860de469442999ed1a0d7992a5efdf2cffc0e3d769
# Build
FROM microservice-sdk-build AS build
ENV NODE_ENV=development
WORKDIR /workspace/app/backend-ts
COPY package.json .npmrc tsconfig.json ./
WORKDIR /workspace
RUN pnpm install

# Run
FROM microservice-sdk-build
WORKDIR /workspace/app/backend-ts
COPY --from=build /workspace/app/backend-ts /workspace/app/backend-ts
COPY --from=build /workspace/node_modules /workspace/node_modules
COPY /src /workspace/app/backend-ts/src
EXPOSE 3001
WORKDIR /workspace
# This is a dev-only image: docker-compose bind-mounts ./src and the
# application writes generated artifacts (OpenAPI spec) back into that
# tree at startup. With `USER node`, host UID/GID mismatch on the bind
# mount causes EACCES. The DS-0002 trivy finding is suppressed for this
# file in `.trivyignore.yaml` — the prod runtime image (`Dockerfile`)
# does run as `node`.
CMD [ "pnpm", "--filter", "backend-ts", "run", "dev" ]
