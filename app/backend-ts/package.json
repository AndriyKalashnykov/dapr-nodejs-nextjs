{
  "name": "backend-ts",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "compile": "tsc",
    "ci": "tsc --noEmit && pnpm run lint && pnpm run prettier",
    "lint": "eslint --max-warnings 0",
    "lint:fix": "eslint --fix",
    "prettier": "prettier -c .",
    "prettier:fix": "prettier --write .",
    "dev": "pnpm run knex -- migrate:latest && tsx watch --import ./src/lib/instrumentation.ts ./src/main.ts",
    "start": "tsx --import ./src/lib/instrumentation.ts src/main.ts",
    "debug": "tsx --import ./src/lib/instrumentation.ts --inspect-brk=0.0.0.0 src/main.ts",
    "test": "NODE_ENV=test vitest --config src/lib/test/vitest.config.ts",
    "test:cov": "NODE_ENV=test vitest --config src/lib/test/vitest.config.ts run --coverage",
    "test:integration": "NODE_ENV=test pnpm run knex -- migrate:latest && NODE_ENV=test vitest --config src/lib/test/vitest.integration.config.ts",
    "test:integration:cov": "NODE_ENV=test pnpm run knex -- migrate:latest && NODE_ENV=test vitest --config src/lib/test/vitest.integration.config.ts run --coverage",
    "knex": "tsx ../../node_modules/knex/bin/cli.js --knexfile ./src/db/knexfile.ts"
  },
  "dependencies": {
    "@dapr/dapr": "^3.6.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.74.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.216.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.216.0",
    "@opentelemetry/resources": "^2.0.0",
    "@opentelemetry/sdk-metrics": "^2.0.0",
    "@opentelemetry/sdk-node": "^0.216.0",
    "@opentelemetry/sdk-trace-node": "^2.0.0",
    "@opentelemetry/semantic-conventions": "^1.30.0",
    "@sos/sdk": "workspace:*",
    "compression": "^1.8.0",
    "express": "^5.1.0",
    "express-zod-api": "^27.0.0",
    "helmet": "^8.1.0",
    "http-errors": "^2.0.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "pg": "^8.13.1",
    "pino": "^10.0.0",
    "swagger-ui-express": "^5.0.1",
    "tsx": "^4.19.3",
    "zod": "~4.3.4"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/compression": "1.8.1",
    "@types/express": "5.0.6",
    "@types/http-errors": "2.0.5",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "24.12.2",
    "@types/supertest": "7.2.0",
    "@types/swagger-ui-express": "4.1.8",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.6.0",
    "prettier": "3.8.3",
    "supertest": "7.2.2",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.1",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.5"
  }
}
