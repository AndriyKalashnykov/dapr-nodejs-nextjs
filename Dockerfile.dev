FROM microservice-build
ENV NODE_ENV=development
WORKDIR /workspace
COPY /packages/@sos/sdk ./packages/@sos/sdk
COPY package.json package-lock.json tsconfig.json .npmrc ./
RUN npm install && npm run compile -w @sos/sdk

