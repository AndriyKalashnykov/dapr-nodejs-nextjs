# syntax=docker/dockerfile:1@sha256:2780b5c3bab67f1f76c781860de469442999ed1a0d7992a5efdf2cffc0e3d769
# Intermediate "SDK already compiled" base image — child Dockerfile.dev's
# (`app/*/Dockerfile.dev`) extend this and drop to `USER node` themselves.
# This image is build-only; no CMD/ENTRYPOINT runs from it directly.
FROM microservice-build
ENV NODE_ENV=development
WORKDIR /workspace
COPY /packages/@sos/sdk ./packages/@sos/sdk
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.json .npmrc ./
RUN pnpm install --frozen-lockfile && pnpm --filter @sos/sdk run compile
